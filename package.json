{
  "name": "prescripto",
  "private": true,
  "workspaces": [
    "frontend",
    "admin",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:admin": "npm run dev --workspace=admin",
    "dev:backend": "npm run server --workspace=backend",
    "dev": "npm run dev:frontend & npm run dev:admin & npm run dev:backend",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
